# API keys and sensitive config
client/config.json
server/config.json

# Sensitive screenshots containing tokens or credentials
deployment/assets/cesium.png

# Runtime/generated files
deployment/acert

# Temporary bug-reproduction screen recordings (kept locally, not source)
/*.webm

# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
dist/
build/

# Splash media files (large files, served from CDN in production)
# Track only the two essential splash clips; the rest are streamed.
client/public/splash/*.mp4
!client/public/splash/video_00.mp4
client/public/splash/*.mp3
!client/public/splash/background_music_00.mp3

# Note: client/assets/media/ holds the master source copies and is fully tracked.

